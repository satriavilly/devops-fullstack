# Stage 1: Build
FROM node:20-alpine AS builder

WORKDIR /app

COPY backend/package*.json ./
RUN npm ci

COPY backend/ ./

RUN npm run build

# Stage 2: Runtime
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production

RUN addgroup -g 1001 nodejs && adduser -S nestjs -u 1001

COPY --from=builder /app/dist ./dist
COPY backend/package*.json ./
RUN npm ci --omit=dev

USER nestjs

EXPOSE 3001

CMD ["node", "dist/main"]
